# ZeroSync Environment Configuration
# copy to .env and adjust values as needed
# all of these have sane defaults so you only need to set what you want to change

# -- networking --
SIGNALING_PORT=4200
SIGNALING_URL=ws://127.0.0.1:4200
CLIENT_PORT=8000

# -- blockchain --
HARDHAT_URL=http://127.0.0.1:8545

# -- model --
INPUT_DIM=4
HIDDEN_UNITS=8
OUTPUT_DIM=2
ACTIVATION=relu
LEARNING_RATE=0.01
EPOCHS=1
BATCH_SIZE=8
NUM_SAMPLES=32

# -- federated learning --
NUM_CLIENTS=4
VECTOR_LEN=4
RNG_BASE_SEED=12345
FIXED_POINT_SCALE=1000

# -- dataset --
# 'synthetic' or 'iris'
DATASET=synthetic

# -- differential privacy --
# set DP_EPSILON > 0 to enable noise injection
# lower epsilon = more privacy but noisier updates
# 0 = disabled (default)
DP_EPSILON=0
DP_DELTA=0.00001
DP_CLIP_NORM=1.0
DP_MECHANISM=gaussian

# -- zk settings --
ZK_PTAU_URL=https://hermez.s3-eu-west-1.amazonaws.com/powersOfTau28_hez_final_10.ptau
ZK_PTAU_FILE=pot10_final.ptau
